# ─────────────────────────────────────────────────────────────
# Vigil — environment configuration
# Copy this file to `.env` and adjust values before starting the stack.
# ─────────────────────────────────────────────────────────────

# --- Domain -----------------------------------------------------
# The only value you need to change to run Vigil under your own domain.
# Traefik routing + ACME certs + the frontend API base URL all derive from this.
DOMAIN=vigil.vboom.io
ACME_EMAIL=admin@vigil.vboom.io
# Let's Encrypt CA server. Use the staging URL below while testing to avoid
# production rate limits, then switch back to the real one for live certs.
#   staging: https://acme-staging-v02.api.letsencrypt.org/directory
ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory

# --- Postgres -----------------------------------------------------
POSTGRES_USER=vigil
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=vigil
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ----------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Backend secrets ---------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-jwt-secret-key
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_SECRET=change-me-fernet-key-44-chars-base64==
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- First-boot admin seed ------------------------------------------
# The seeded admin is forced to change this password on first login.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin123!

# --- Prometheus / alert engine ----------------------------------------
PROMETHEUS_URL=http://prometheus:9090
ALERT_EVAL_INTERVAL_SECONDS=15
NODE_EXPORTER_VERSION=1.8.2
NODE_EXPORTER_PORT=9100

# --- CORS (frontend origin, only needed outside Traefik same-domain setups) ---
BACKEND_CORS_ORIGINS=["https://vigil.vboom.io"]
